#!/usr/bin/env bash
#
# wt-create - Git worktree creation with memorable random names
#
# Usage: wt-create [OPTIONS] [BRANCH]
#        wt-create help
#
# Creates git worktrees as siblings to the main repository in <repo>-worktrees/
#
# Environment variables:
#   WT_CREATE_RETRIES - Max attempts for unique name generation (default: 10)
#   WORKTREE_INIT_SCRIPT - Worktree init script path (default: fab/.kit/worktree-init.sh)

set -euo pipefail

# ============================================================================
# Initialization
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wt-common.sh"

WT_CREATE_RETRIES="${WT_CREATE_RETRIES:-$WT_DEFAULT_RETRIES}"

# ============================================================================
# Name Generation
# ============================================================================

# Generate a unique random name with retry logic
wt_generate_unique_name() {
    local attempt=0
    local name

    while ((attempt < WT_CREATE_RETRIES)); do
        name=$(wt_generate_random_name)
        if ! wt_check_name_collision "$name"; then
            echo "$name"
            return 0
        fi
        ((attempt++))
    done

    wt_error_with_code "$WT_EXIT_RETRY_EXHAUSTED" \
        "Could not find unique worktree name" \
        "All $WT_CREATE_RETRIES random name attempts collided with existing worktrees" \
        "Remove some worktrees from $WT_WORKTREES_DIR or increase WT_CREATE_RETRIES"
}

# ============================================================================
# Worktree Creation (wt-create specific)
# ============================================================================

# Create an exploratory worktree with given name
wt_create_exploratory_worktree() {
    local name="$1"

    wt_ensure_worktrees_dir

    local wt_path="$WT_WORKTREES_DIR/$name"
    local branch="wt/$name"

    wt_create_worktree "$wt_path" "$branch" "new"
    wt_print_success "$name" "$wt_path" "$branch"

    WT_PATH="$wt_path"
}

# ============================================================================
# Help
# ============================================================================

wt_show_help() {
    local worktrees_path="<repo>-worktrees/"
    if git rev-parse --git-common-dir &>/dev/null; then
        local git_common_dir repo_root repo_name
        git_common_dir=$(git rev-parse --git-common-dir)
        repo_root="${git_common_dir%/.git}"
        repo_name=$(basename "$repo_root")
        worktrees_path="$(dirname "$repo_root")/${repo_name}-worktrees/"
    fi

    cat <<EOF
Usage: wt-create [OPTIONS] [BRANCH]

Creates a git worktree for parallel development.

Arguments:
  BRANCH    Branch to checkout (optional)
            If omitted, creates wt/<random-name> branch

Worktrees created at: $worktrees_path

Options:
  --worktree-name <name>   Set worktree name (skips name prompt)
  --worktree-init <bool>   Run worktree init script: true (default) or false
  --worktree-open <app>    Open in app after creation, or 'skip' to not open
                           Apps: code, cursor, ghostty, tmux_window, byobu_tab
                           Default: app menu (interactive), skip (non-interactive)
  --reuse                  Reuse existing worktree if name collides (requires --worktree-name)
  --non-interactive        Use defaults, no prompts, porcelain output
                           (only worktree path on stdout; messages on stderr)
  help                     Show this help message

Environment:
  WT_CREATE_RETRIES        Max attempts for unique name (default: 10)
  WORKTREE_INIT_SCRIPT     Worktree init script (default: fab/.kit/worktree-init.sh)

Examples:
  wt-create                                    # Interactive: prompts for name, runs init
  wt-create feature/auth                       # Worktree for existing branch
  wt-create --worktree-name my-wt              # Use specific name, no prompt
  wt-create --worktree-open code               # Create and open in VSCode
  wt-create --worktree-init false              # Skip init script
  wt-create --non-interactive                  # Fully automated with defaults
  wt-create --non-interactive --worktree-open cursor  # Automated, open in Cursor
EOF
}

# ============================================================================
# Main Entry Point
# ============================================================================

main() {
    local branch_arg=""
    local non_interactive=""
    local worktree_name=""
    local worktree_init=""
    local worktree_open=""
    local reuse=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            help|--help|-h)
                wt_show_help
                exit "$WT_EXIT_SUCCESS"
                ;;
            --non-interactive)
                non_interactive="true"
                shift
                ;;
            --reuse)
                reuse="true"
                shift
                ;;
            --worktree-name)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing worktree name" \
                        "--worktree-name requires an argument" \
                        "Example: wt-create --worktree-name my-feature"
                fi
                worktree_name="$2"
                shift 2
                ;;
            --worktree-init)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing value for --worktree-init" \
                        "--worktree-init requires 'true' or 'false'" \
                        "Example: wt-create --worktree-init false"
                fi
                if [[ "$2" != "true" && "$2" != "false" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Invalid value for --worktree-init: $2" \
                        "--worktree-init accepts 'true' or 'false'" \
                        "Example: wt-create --worktree-init false"
                fi
                worktree_init="$2"
                shift 2
                ;;
            --worktree-open)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing value for --worktree-open" \
                        "--worktree-open requires an app name or 'skip'" \
                        "Example: wt-create --worktree-open code"
                fi
                worktree_open="$2"
                shift 2
                ;;
            -*)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unknown option: $1" \
                    "This option is not recognized" \
                    "Run 'wt-create help' for usage information"
                ;;
            *)
                if [[ -z "$branch_arg" ]]; then
                    branch_arg="$1"
                else
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Too many arguments" \
                        "Only one branch name can be specified" \
                        "Run 'wt-create help' for usage information"
                fi
                shift
                ;;
        esac
    done

    # Apply defaults
    worktree_init="${worktree_init:-true}"
    if [[ -z "$worktree_open" ]]; then
        if [[ "$non_interactive" == "true" ]]; then
            worktree_open="skip"
        else
            worktree_open="prompt"
        fi
    fi

    # Validate --reuse requires --worktree-name
    if [[ "$reuse" == "true" && -z "$worktree_name" ]]; then
        wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
            "--reuse requires --worktree-name" \
            "--reuse only works with an explicit worktree name" \
            "Example: wt-create --reuse --worktree-name my-feature branch-name"
    fi

    wt_validate_git_repo
    wt_get_repo_context

    # Set up traps for rollback on failure and signal cleanup
    trap wt_rollback EXIT
    trap wt_cleanup_on_signal INT TERM

    # Validate branch name before any git operations
    if [[ -n "$branch_arg" ]]; then
        if ! wt_validate_branch_name "$branch_arg"; then
            wt_error "Invalid branch name" \
                "Branch name '$branch_arg' contains invalid characters" \
                "Use alphanumeric characters, hyphens, and single slashes"
        fi
    fi

    # Dirty-state check
    if [[ "$non_interactive" != "true" ]] && \
       (wt_has_uncommitted_changes || wt_has_untracked_files); then
        echo "${WT_YELLOW}Warning: main repo has uncommitted changes${WT_RESET}"
        wt_show_menu "How to proceed?" "" \
            "Continue anyway" \
            "Stash changes first" \
            "Abort"
        case "$WT_MENU_CHOICE" in
            1) ;; # continue
            2) wt_stash_create "wt-create: pre-creation stash" >/dev/null ;;
            3) wt_disarm_rollback; exit 0 ;;
            0) wt_disarm_rollback; exit 0 ;;
        esac
    fi

    # Determine suggested name
    local suggested_name
    if [[ -z "$branch_arg" ]]; then
        suggested_name=$(wt_generate_unique_name)
    else
        suggested_name=$(wt_derive_worktree_name "$branch_arg")
    fi

    # Resolve final name
    local final_name
    if [[ -n "$worktree_name" ]]; then
        final_name="$worktree_name"
    elif [[ "$non_interactive" == "true" ]]; then
        final_name="$suggested_name"
    else
        read -p "Worktree name [$suggested_name]: " final_name
        final_name="${final_name:-$suggested_name}"
    fi

    # Check collision
    if wt_check_name_collision "$final_name"; then
        if [[ "$reuse" == "true" ]]; then
            # Reuse existing worktree — skip creation, init, and open
            echo "Reusing existing worktree: $final_name" >&2
            wt_disarm_rollback
            echo "$WT_WORKTREES_DIR/$final_name"
            return 0
        fi
        wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
            "Worktree '$final_name' already exists" \
            "A worktree with this name already exists at $WT_WORKTREES_DIR/$final_name" \
            "Remove the existing worktree or use a different branch name"
    fi

    # Create worktree
    # In non-interactive mode, redirect human-readable messages to stderr
    # so stdout contains only the worktree path (porcelain output contract)
    if [[ -z "$branch_arg" ]]; then
        if [[ "$non_interactive" == "true" ]]; then
            wt_create_exploratory_worktree "$final_name" >&2
        else
            wt_create_exploratory_worktree "$final_name"
        fi
    else
        if [[ "$non_interactive" == "true" ]]; then
            wt_create_branch_worktree "$branch_arg" "$final_name" >&2
        else
            wt_create_branch_worktree "$branch_arg" "$final_name"
        fi
    fi

    # Setup
    if [[ "$worktree_init" == "true" ]]; then
        if [[ "$non_interactive" == "true" ]]; then
            wt_run_worktree_setup "$WT_PATH" "force" >&2
        elif [[ -z "$branch_arg" ]]; then
            wt_run_worktree_setup "$WT_PATH" "force"
        else
            wt_run_worktree_setup "$WT_PATH"
        fi
    fi

    # Open
    if [[ "$worktree_open" == "prompt" ]]; then
        "$SCRIPT_DIR/wt-open" "$WT_PATH"
    elif [[ "$worktree_open" != "skip" ]]; then
        "$SCRIPT_DIR/wt-open" --app "$worktree_open" "$WT_PATH"
    fi

    # Success — disarm rollback before final output
    wt_disarm_rollback

    # Always output the full path as the last line
    echo "$WT_PATH"
}

main "$@"
