#!/usr/bin/env bash
#
# wt-pr - Create a git worktree from a GitHub PR
#
# Usage: wt-pr [OPTIONS] [PR_NUMBER]
#        wt-pr help
#
# Creates a git worktree for reviewing a pull request.
# Requires the GitHub CLI (gh) to be installed and authenticated.
#
# Environment variables:
#   WORKTREE_INIT_SCRIPT - Worktree init script path (default: fab/.kit/worktree-init.sh)

set -euo pipefail

# ============================================================================
# Initialization
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wt-common.sh"

# ============================================================================
# GitHub CLI
# ============================================================================

# Validate that gh CLI is available
wt_require_gh() {
    if ! command -v gh &>/dev/null; then
        wt_error "gh CLI not found" \
            "wt-pr requires the GitHub CLI to interact with pull requests" \
            "Install it from https://cli.github.com/ and run 'gh auth login'"
    fi
}

# Get the branch name for a PR number
# Args: $1 = PR number
# Stdout: branch name
wt_get_pr_branch() {
    local pr="$1"
    local branch
    branch=$(gh pr view "$pr" --json headRefName --jq .headRefName 2>/dev/null) || {
        wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
            "Failed to get PR #$pr" \
            "gh pr view failed — the PR may not exist or gh may not be authenticated" \
            "Run 'gh pr view $pr' to debug"
    }
    if [[ -z "$branch" ]]; then
        wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
            "PR #$pr has no branch" \
            "Could not determine the head branch for this PR" \
            "Run 'gh pr view $pr --json headRefName' to debug"
    fi
    echo "$branch"
}

# List open PRs and let user select one
# Stdout: selected PR number
wt_select_pr_interactive() {
    local pr_json
    pr_json=$(gh pr list --json number,title,headRefName --limit 20 2>/dev/null) || {
        wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
            "Failed to list PRs" \
            "gh pr list failed — check authentication with 'gh auth status'" \
            "Run 'gh pr list' to debug"
    }

    local count
    count=$(echo "$pr_json" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
        wt_error "No open pull requests" \
            "There are no open PRs in this repository" \
            "Specify a PR number directly: wt-pr <number>"
    fi

    # Build menu options
    local options=()
    local pr_numbers=()
    for i in $(seq 0 $((count - 1))); do
        local num title branch
        num=$(echo "$pr_json" | jq -r ".[$i].number")
        title=$(echo "$pr_json" | jq -r ".[$i].title")
        branch=$(echo "$pr_json" | jq -r ".[$i].headRefName")
        options+=("#$num $title ($branch)")
        pr_numbers+=("$num")
    done

    wt_show_menu "Select a pull request:" "" "${options[@]}"

    if [[ "$WT_MENU_CHOICE" == "0" ]]; then
        echo "Cancelled." >&2
        exit "$WT_EXIT_SUCCESS"
    fi

    echo "${pr_numbers[$((WT_MENU_CHOICE - 1))]}"
}

# ============================================================================
# Help
# ============================================================================

wt_show_help() {
    cat <<EOF
Usage: wt-pr [OPTIONS] [PR_NUMBER]

Creates a git worktree for reviewing a GitHub pull request.

Arguments:
  PR_NUMBER   Pull request number (optional in interactive mode)

Requires: GitHub CLI (gh) — install from https://cli.github.com/

Options:
  --worktree-name <name>   Set worktree name (default: derived from branch)
  --worktree-init <bool>   Run worktree init script: true (default) or false
  --worktree-open <app>    Open in app after creation, or 'skip' to not open
                           Apps: code, cursor, ghostty, tmux_window, byobu_tab
                           Default: app menu (interactive), skip (non-interactive)
  --non-interactive        Use defaults for all options, no prompts
  help                     Show this help message

Examples:
  wt-pr                                        # Interactive: select from open PRs
  wt-pr 42                                     # Create worktree for PR #42
  wt-pr 42 --worktree-name review-42           # Custom worktree name
  wt-pr 42 --non-interactive                   # Fully automated
  wt-pr 42 --non-interactive --worktree-open cursor  # Automated, open in Cursor
EOF
}

# ============================================================================
# Main Entry Point
# ============================================================================

main() {
    local pr_number=""
    local non_interactive=""
    local worktree_name=""
    local worktree_init=""
    local worktree_open=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            help|--help|-h)
                wt_show_help
                exit "$WT_EXIT_SUCCESS"
                ;;
            --non-interactive)
                non_interactive="true"
                shift
                ;;
            --worktree-name)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing worktree name" \
                        "--worktree-name requires an argument" \
                        "Example: wt-pr 42 --worktree-name review-42"
                fi
                worktree_name="$2"
                shift 2
                ;;
            --worktree-init)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing value for --worktree-init" \
                        "--worktree-init requires 'true' or 'false'" \
                        "Example: wt-pr 42 --worktree-init false"
                fi
                if [[ "$2" != "true" && "$2" != "false" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Invalid value for --worktree-init: $2" \
                        "--worktree-init accepts 'true' or 'false'" \
                        "Example: wt-pr 42 --worktree-init false"
                fi
                worktree_init="$2"
                shift 2
                ;;
            --worktree-open)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing value for --worktree-open" \
                        "--worktree-open requires an app name or 'skip'" \
                        "Example: wt-pr 42 --worktree-open code"
                fi
                worktree_open="$2"
                shift 2
                ;;
            -*)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unknown option: $1" \
                    "This option is not recognized" \
                    "Run 'wt-pr help' for usage information"
                ;;
            *)
                if [[ -z "$pr_number" ]]; then
                    pr_number="$1"
                else
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Too many arguments" \
                        "Only one PR number can be specified" \
                        "Run 'wt-pr help' for usage information"
                fi
                shift
                ;;
        esac
    done

    # Apply defaults
    worktree_init="${worktree_init:-true}"
    if [[ -z "$worktree_open" ]]; then
        if [[ "$non_interactive" == "true" ]]; then
            worktree_open="skip"
        else
            worktree_open="prompt"
        fi
    fi

    wt_require_gh
    wt_validate_git_repo
    wt_get_repo_context

    # Set up traps
    trap wt_rollback EXIT
    trap wt_cleanup_on_signal INT TERM

    # Resolve PR number
    if [[ -z "$pr_number" ]]; then
        if [[ "$non_interactive" == "true" ]]; then
            wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                "No PR number specified" \
                "PR number is required in non-interactive mode" \
                "Example: wt-pr --non-interactive 42"
        fi
        pr_number=$(wt_select_pr_interactive)
    fi

    # Get branch name from PR
    local branch
    branch=$(wt_get_pr_branch "$pr_number")

    # Validate branch name
    if ! wt_validate_branch_name "$branch"; then
        wt_error "Invalid branch name" \
            "PR #$pr_number has branch '$branch' which contains invalid characters" \
            "This is unexpected — contact the PR author"
    fi

    # Resolve worktree name
    local suggested_name
    suggested_name=$(wt_derive_worktree_name "$branch")

    local final_name
    if [[ -n "$worktree_name" ]]; then
        final_name="$worktree_name"
    elif [[ "$non_interactive" == "true" ]]; then
        final_name="$suggested_name"
    else
        read -p "Worktree name [$suggested_name]: " final_name
        final_name="${final_name:-$suggested_name}"
    fi

    # Check collision
    if wt_check_name_collision "$final_name"; then
        wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
            "Worktree '$final_name' already exists" \
            "A worktree with this name already exists at $WT_WORKTREES_DIR/$final_name" \
            "Remove the existing worktree or use --worktree-name to pick a different name"
    fi

    # Create worktree (delegates to shared function which handles fetch/local/new)
    echo "Creating worktree for PR #$pr_number (branch: $branch)..."
    wt_create_branch_worktree "$branch" "$final_name"

    # Setup
    if [[ "$worktree_init" == "true" ]]; then
        if [[ "$non_interactive" == "true" ]]; then
            wt_run_worktree_setup "$WT_PATH" "force"
        else
            wt_run_worktree_setup "$WT_PATH"
        fi
    fi

    # Open
    if [[ "$worktree_open" == "prompt" ]]; then
        "$SCRIPT_DIR/wt-open" "$WT_PATH"
    elif [[ "$worktree_open" != "skip" ]]; then
        "$SCRIPT_DIR/wt-open" --app "$worktree_open" "$WT_PATH"
    fi

    # Success — disarm rollback
    wt_disarm_rollback

    # Always output the full path as the last line
    echo "$WT_PATH"
}

main "$@"
