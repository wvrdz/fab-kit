#!/usr/bin/env bash
#
# wt-delete - Git worktree deletion with cleanup
#
# Usage: wt-delete [OPTIONS]
#        wt-delete help
#
# Deletes git worktrees with optional branch cleanup

set -euo pipefail

# ============================================================================
# Initialization
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wt-common.sh"

# ============================================================================
# Worktree Information
# ============================================================================

# Get current worktree info (name, branch, path)
# Sets: WT_NAME, WT_BRANCH, WT_PATH
wt_get_current_worktree_info() {
    if ! wt_is_worktree; then
        return 1
    fi

    WT_PATH=$(git rev-parse --show-toplevel 2>/dev/null)
    WT_NAME=$(basename "$WT_PATH")
    WT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
}

# List worktrees in formatted output
wt_list_worktrees_formatted() {
    wt_get_repo_context
    local current_path
    current_path=$(pwd -P)

    echo "Worktrees:"

    while IFS=$'\t' read -r path branch; do
        local name marker=""

        if [[ "$path" == "$current_path" ]]; then
            marker="* "
        fi

        if [[ "$path" == "$WT_REPO_ROOT" ]]; then
            name="(main)"
        else
            name=$(basename "$path")
        fi

        printf "  %s%-12s %-20s %s\n" "$marker" "$name" "$branch" "$path"
    done < <(wt_list_worktrees)
}

# ============================================================================
# Branch Operations
# ============================================================================

# Check if branch exists on remote
wt_branch_on_remote() {
    local branch="$1"
    git ls-remote --heads origin "$branch" 2>/dev/null | grep -q "refs/heads/${branch}$"
}

# Delete local branch
wt_delete_local_branch() {
    local branch="$1"
    local force="${2:-}"

    if [[ "$force" == "force" ]]; then
        git branch -D "$branch" 2>/dev/null
    else
        git branch -d "$branch" 2>/dev/null
    fi
}

# Delete remote branch
wt_delete_remote_branch() {
    local branch="$1"
    git push origin --delete "$branch" 2>/dev/null
}

# Handle remote branch deletion
# Args: $1 = branch, $2 = delete_remote ("true"/"false")
wt_handle_remote_branch_deletion() {
    local branch="$1"
    local delete_remote="$2"

    if ! wt_branch_on_remote "$branch"; then
        return 0
    fi

    if [[ "$delete_remote" == "true" ]]; then
        if wt_delete_remote_branch "$branch"; then
            echo "Deleted branch: $branch (remote)"
        else
            echo "${WT_YELLOW}Note:${WT_RESET} Could not delete remote branch"
        fi
    fi
}

# ============================================================================
# Worktree Operations
# ============================================================================

# Remove worktree
wt_remove_worktree() {
    local wt_path="$1"
    local force="${2:-}"

    if [[ "$force" == "force" ]]; then
        git worktree remove --force "$wt_path" 2>/dev/null
    else
        git worktree remove "$wt_path" 2>/dev/null
    fi

    # Clean up stale worktree metadata so git doesn't think
    # branches are still checked out in the removed worktree
    git worktree prune 2>/dev/null || true
}

# ============================================================================
# Core Deletion Logic
# ============================================================================

# Handle uncommitted changes
# Args: $1 = worktree name, $2 = stash_flag, $3 = non_interactive
wt_handle_uncommitted_changes() {
    local wt_name="$1"
    local stash_flag="${2:-}"
    local non_interactive="${3:-}"

    local date_str
    date_str=$(date +%Y-%m-%d)

    if [[ "$stash_flag" == "stash" ]]; then
        echo "Stashing changes..."
        local hash
        hash=$(wt_stash_create "wt-delete: saved from worktree '$wt_name' on $date_str")
        if [[ -n "$hash" ]]; then
            echo "Changes stashed (hash: $hash). Recover with 'git stash list' or 'git stash apply $hash'"
            wt_register_rollback "cd '$(pwd)' && git stash apply '$hash' 2>/dev/null"
        fi
        return 0
    fi

    if [[ "$non_interactive" == "true" ]]; then
        echo "Discarding uncommitted changes..."
        return 0
    fi

    echo ""
    echo "${WT_YELLOW}Warning:${WT_RESET} Worktree has uncommitted changes"
    echo ""

    wt_show_menu "What would you like to do?" 1 \
        "Stash changes and delete (Recommended)" \
        "Discard changes and delete"

    case "$WT_MENU_CHOICE" in
        1)
            echo "Stashing changes..."
            local hash
            hash=$(wt_stash_create "wt-delete: saved from worktree '$wt_name' on $date_str")
            if [[ -n "$hash" ]]; then
                echo "Changes stashed (hash: $hash). Recover with 'git stash list' or 'git stash apply $hash'"
                wt_register_rollback "cd '$(pwd)' && git stash apply '$hash' 2>/dev/null"
            fi
            return 0
            ;;
        2)
            echo "Discarding changes..."
            return 0
            ;;
        0)
            echo "Cancelled."
            exit "$WT_EXIT_SUCCESS"
            ;;
    esac
}

# Handle unpushed commits warning
# Args: $1 = branch, $2 = non_interactive
wt_handle_unpushed_commits() {
    local branch="$1"
    local non_interactive="${2:-}"

    if [[ "$non_interactive" == "true" ]]; then
        return 0
    fi

    local count
    count=$(wt_get_unpushed_count "$branch")

    echo ""
    echo "${WT_YELLOW}Warning:${WT_RESET} Branch has $count unpushed commit(s)"
    echo ""
    echo "Commits that will be lost:"
    git log "origin/${branch}..${branch}" --oneline 2>/dev/null | head -5 | sed 's/^/  /'
    if ((count > 5)); then
        echo "  ... and $((count - 5)) more"
    fi
    echo ""

    wt_show_menu "Continue anyway?" 0 \
        "Yes, delete (commits will be lost)"

    case "$WT_MENU_CHOICE" in
        1)
            return 0
            ;;
        0)
            echo "Cancelled."
            exit "$WT_EXIT_SUCCESS"
            ;;
    esac
}

# Delete branch and remote for a worktree
# Args: $1 = branch, $2 = wt_name, $3 = delete_branch, $4 = delete_remote
wt_handle_branch_cleanup() {
    local branch="$1"
    local wt_name="$2"
    local delete_branch="$3"
    local delete_remote="$4"

    if [[ "$delete_branch" != "true" || -z "$branch" ]]; then
        return 0
    fi

    if wt_delete_local_branch "$branch" "force" 2>/dev/null; then
        echo "Deleted branch: $branch (local)"
    fi
    wt_handle_remote_branch_deletion "$branch" "$delete_remote"

    # Also clean up the wt/ branch associated with this worktree folder
    # (when user switched to a feature branch, the original wt/ branch is orphaned)
    local wt_origin_branch="wt/$wt_name"
    if [[ "$wt_origin_branch" != "$branch" ]]; then
        if wt_delete_local_branch "$wt_origin_branch" "force" 2>/dev/null; then
            echo "Deleted branch: $wt_origin_branch (local)"
        fi
        wt_handle_remote_branch_deletion "$wt_origin_branch" "$delete_remote"
    fi
}

# Delete current worktree
wt_delete_current_worktree() {
    local non_interactive="$1"
    local delete_branch="$2"
    local delete_remote="$3"
    local stash_flag="$4"

    if ! wt_get_current_worktree_info; then
        wt_error "Not in a worktree" \
            "wt-delete without --worktree-name only works from within a worktree" \
            "Specify a worktree: wt-delete --worktree-name <name>"
    fi

    wt_get_repo_context

    echo "Worktree: ${WT_BOLD}$WT_NAME${WT_RESET}"
    echo "Branch: $WT_BRANCH"
    echo "Path: $WT_PATH"
    echo ""

    # Handle uncommitted changes
    if wt_has_uncommitted_changes || wt_has_untracked_files; then
        wt_handle_uncommitted_changes "$WT_NAME" "$stash_flag" "$non_interactive"
    fi

    # Check for unpushed commits
    if wt_has_unpushed_commits "$WT_BRANCH" 2>/dev/null; then
        wt_handle_unpushed_commits "$WT_BRANCH" "$non_interactive"
    fi

    # Confirmation
    if [[ "$non_interactive" != "true" ]]; then
        wt_show_menu "Delete this worktree?" 0 \
            "Yes, delete"

        case "$WT_MENU_CHOICE" in
            0)
                echo "Cancelled."
                exit "$WT_EXIT_SUCCESS"
                ;;
        esac
    fi

    # Change to main repo before deletion
    cd "$WT_REPO_ROOT" || wt_error "Cannot change to main repo" \
        "Failed to cd to $WT_REPO_ROOT" \
        "Check if the main repository still exists"

    # Remove the worktree
    echo "Removing worktree..."
    wt_remove_worktree "$WT_PATH" "force"
    echo "Deleted worktree: ${WT_GREEN}$WT_NAME${WT_RESET}"

    # Handle branch cleanup
    wt_handle_branch_cleanup "$WT_BRANCH" "$WT_NAME" "$delete_branch" "$delete_remote"

    echo ""
    echo "You are no longer in a valid directory."
    echo "Run: ${WT_BOLD}cd $WT_REPO_ROOT${WT_RESET}"
}

# Delete worktree by name
wt_delete_worktree_by_name() {
    local name="$1"
    local non_interactive="$2"
    local delete_branch="$3"
    local delete_remote="$4"
    local stash_flag="$5"

    wt_get_repo_context

    local wt_path
    wt_path=$(wt_get_worktree_path_by_name "$name") || true

    if [[ -z "$wt_path" ]]; then
        echo "${WT_RED}Error:${WT_RESET} Worktree '$name' not found" >&2
        echo "  ${WT_BOLD}Why:${WT_RESET} No worktree with that name exists" >&2
        echo "  ${WT_BOLD}Fix:${WT_RESET} Use one of the available worktrees:" >&2
        echo "" >&2
        wt_list_worktrees_formatted >&2
        exit "$WT_EXIT_GENERAL_ERROR"
    fi

    # Get branch for the worktree
    local branch
    branch=$(git worktree list --porcelain | awk -v path="$wt_path" '
        /^worktree / { current_path = substr($0, 10) }
        /^branch / && current_path == path {
            branch = substr($0, 8)
            gsub(/refs\/heads\//, "", branch)
            print branch
        }
    ')

    echo "Worktree: ${WT_BOLD}$name${WT_RESET}"
    echo "Branch: $branch"
    echo "Path: $wt_path"
    echo ""

    # Handle stash
    if [[ "$stash_flag" == "stash" ]]; then
        if (cd "$wt_path" && git diff --quiet HEAD 2>/dev/null && git diff --cached --quiet HEAD 2>/dev/null) && \
           [[ -z "$(cd "$wt_path" && git ls-files --others --exclude-standard 2>/dev/null)" ]]; then
            : # No changes to stash
        else
            echo "Stashing changes..."
            local date_str hash
            date_str=$(date +%Y-%m-%d)
            hash=$(cd "$wt_path" && wt_stash_create "wt-delete: saved from worktree '$name' on $date_str")
            if [[ -n "$hash" ]]; then
                echo "Changes stashed (hash: $hash). Recover with 'git stash list' or 'git stash apply $hash'"
                wt_register_rollback "cd '$wt_path' && git stash apply '$hash' 2>/dev/null"
            fi
        fi
    fi

    # Confirmation
    if [[ "$non_interactive" != "true" ]]; then
        wt_show_menu "Delete this worktree?" 0 \
            "Yes, delete"

        case "$WT_MENU_CHOICE" in
            0)
                echo "Cancelled."
                exit "$WT_EXIT_SUCCESS"
                ;;
        esac
    fi

    # Remove the worktree
    echo "Removing worktree..."
    wt_remove_worktree "$wt_path" "force"
    echo "Deleted worktree: ${WT_GREEN}$name${WT_RESET}"

    # Handle branch cleanup
    wt_handle_branch_cleanup "$branch" "$name" "$delete_branch" "$delete_remote"
}

# Show worktree selection menu
wt_select_worktree_menu() {
    local non_interactive="$1"
    local delete_branch="$2"
    local delete_remote="$3"
    local stash_flag="$4"

    wt_get_repo_context

    # Get list of worktrees (excluding main repo)
    local worktrees=()
    local names=()
    local default_idx=2  # Default to first individual worktree (after "All")

    # Find most recently modified worktree
    local newest_path=""
    local newest_time=0

    while IFS=$'\t' read -r path branch; do
        if [[ "$path" != "$WT_REPO_ROOT" ]]; then
            local name
            name=$(basename "$path")
            worktrees+=("$path")
            names+=("$name ($branch)")

            # Track most recent
            if [[ -d "$path" ]]; then
                local mtime
                mtime=$(stat -c %Y "$path" 2>/dev/null || stat -f %m "$path" 2>/dev/null || echo 0)
                if ((mtime > newest_time)); then
                    newest_time=$mtime
                    newest_path="$path"
                fi
            fi
        fi
    done < <(wt_list_worktrees)

    if [[ ${#worktrees[@]} -eq 0 ]]; then
        echo "No worktrees found."
        exit "$WT_EXIT_SUCCESS"
    fi

    # Find index of newest worktree
    if [[ -n "$newest_path" ]]; then
        for i in "${!worktrees[@]}"; do
            if [[ "${worktrees[$i]}" == "$newest_path" ]]; then
                default_idx=$((i + 2))  # +2: +1 for 1-based, +1 for "All" entry
                break
            fi
        done
    fi

    # Prepend "All" option
    local all_label="All (${#worktrees[@]} worktrees)"
    local menu_names=("$all_label" "${names[@]}")

    wt_show_menu "Select worktree to delete:" "$default_idx" "${menu_names[@]}"

    if [[ "$WT_MENU_CHOICE" == "0" ]]; then
        echo "Cancelled."
        exit "$WT_EXIT_SUCCESS"
    fi

    if [[ "$WT_MENU_CHOICE" == "1" ]]; then
        wt_delete_all_worktrees "$non_interactive" "$delete_branch" "$delete_remote" "$stash_flag"
        return
    fi

    local selected_name
    selected_name=$(basename "${worktrees[$((WT_MENU_CHOICE - 2))]}")
    wt_delete_worktree_by_name "$selected_name" "$non_interactive" "$delete_branch" "$delete_remote" "$stash_flag"
}

# Delete all worktrees for the repository
wt_delete_all_worktrees() {
    local non_interactive="$1"
    local delete_branch="$2"
    local delete_remote="$3"
    local stash_flag="$4"

    wt_get_repo_context

    # If we're currently in a worktree, cd to main repo
    if wt_is_worktree; then
        cd "$WT_REPO_ROOT" || wt_error "Cannot change to main repo" \
            "Failed to cd to $WT_REPO_ROOT" \
            "Check if the main repository still exists"
    fi

    # Get list of worktrees (excluding main repo)
    local worktree_names=()

    while IFS=$'\t' read -r path branch; do
        if [[ "$path" != "$WT_REPO_ROOT" ]]; then
            worktree_names+=("$(basename "$path")")
        fi
    done < <(wt_list_worktrees)

    if [[ ${#worktree_names[@]} -eq 0 ]]; then
        echo "No worktrees found."
        exit "$WT_EXIT_SUCCESS"
    fi

    echo "Found ${#worktree_names[@]} worktree(s):"
    for name in "${worktree_names[@]}"; do
        echo "  $name"
    done
    echo ""

    # Confirmation
    if [[ "$non_interactive" != "true" ]]; then
        wt_show_menu "Delete ALL ${#worktree_names[@]} worktree(s)?" \
            "Yes, delete all"

        case "$WT_MENU_CHOICE" in
            0)
                echo "Cancelled."
                exit "$WT_EXIT_SUCCESS"
                ;;
        esac
    fi

    for name in "${worktree_names[@]}"; do
        echo ""
        echo "--- Deleting: $name ---"
        wt_delete_worktree_by_name "$name" "true" "$delete_branch" "$delete_remote" "$stash_flag"
    done
}

# ============================================================================
# Help
# ============================================================================

wt_show_help() {
    cat <<EOF
Usage: wt-delete [OPTIONS]
       wt-delete help

Deletes a git worktree with optional branch cleanup.

Options:
  --worktree-name <name>   Worktree to delete (default: current worktree or selection menu)
  --delete-branch <bool>   Delete associated branch: true (default) or false
  --delete-remote <bool>   Delete remote branch: true (default) or false
  --delete-all             Delete all worktrees for the repository
  --stash, -s              Stash uncommitted changes before deleting
  --non-interactive        Use defaults for all options, no prompts
  help                     Show this help message

Worktree Resolution:
  1. --worktree-name <name>    Use specified worktree
  2. Current directory          If inside a worktree, use it
  3. Interactive selection       Show menu (interactive mode only)

Exit Codes:
  0    Success
  1    General error
  2    Invalid arguments
  3    Git operation failed

Examples:
  wt-delete                                    # Current worktree, or menu with "All" option
  wt-delete --worktree-name london             # Delete worktree named 'london'
  wt-delete --non-interactive                  # Delete current worktree, no prompts
  wt-delete --delete-branch false              # Delete worktree, keep branch
  wt-delete --delete-remote false              # Delete worktree + local branch, keep remote
  wt-delete --stash --worktree-name london     # Stash changes then delete
  wt-delete --delete-all                       # Delete all worktrees
  wt-delete --delete-all --non-interactive     # Delete all worktrees, no prompts
EOF
}

# ============================================================================
# Main Entry Point
# ============================================================================

main() {
    local worktree_name=""
    local non_interactive=""
    local delete_remote=""
    local delete_branch=""
    local delete_all=""
    local stash_flag=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            help|--help|-h)
                wt_show_help
                exit "$WT_EXIT_SUCCESS"
                ;;
            --non-interactive)
                non_interactive="true"
                shift
                ;;
            --worktree-name)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing worktree name" \
                        "--worktree-name requires an argument" \
                        "Example: wt-delete --worktree-name my-feature"
                fi
                worktree_name="$2"
                shift 2
                ;;
            --delete-remote)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing value for --delete-remote" \
                        "--delete-remote requires 'true' or 'false'" \
                        "Example: wt-delete --delete-remote false"
                fi
                if [[ "$2" != "true" && "$2" != "false" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Invalid value for --delete-remote: $2" \
                        "--delete-remote accepts 'true' or 'false'" \
                        "Example: wt-delete --delete-remote false"
                fi
                delete_remote="$2"
                shift 2
                ;;
            --delete-branch)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing value for --delete-branch" \
                        "--delete-branch requires 'true' or 'false'" \
                        "Example: wt-delete --delete-branch false"
                fi
                if [[ "$2" != "true" && "$2" != "false" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Invalid value for --delete-branch: $2" \
                        "--delete-branch accepts 'true' or 'false'" \
                        "Example: wt-delete --delete-branch false"
                fi
                delete_branch="$2"
                shift 2
                ;;
            --delete-all)
                delete_all="true"
                shift
                ;;
            --stash|-s)
                stash_flag="stash"
                shift
                ;;
            -*)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unknown option: $1" \
                    "This option is not recognized" \
                    "Run 'wt-delete help' for usage information"
                ;;
            *)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unexpected argument: $1" \
                    "Use --worktree-name to specify a worktree" \
                    "Run 'wt-delete help' for usage information"
                ;;
        esac
    done

    # Apply defaults
    delete_remote="${delete_remote:-true}"
    delete_branch="${delete_branch:-true}"

    wt_validate_git_repo

    # Set up signal traps for cleanup on interruption
    trap wt_cleanup_on_signal INT TERM

    # Handle --delete-all
    if [[ "$delete_all" == "true" ]]; then
        wt_delete_all_worktrees "$non_interactive" "$delete_branch" "$delete_remote" "$stash_flag"
        return
    fi

    # Resolve worktree target
    if [[ -n "$worktree_name" ]]; then
        wt_delete_worktree_by_name "$worktree_name" "$non_interactive" "$delete_branch" "$delete_remote" "$stash_flag"
    elif wt_is_worktree; then
        wt_delete_current_worktree "$non_interactive" "$delete_branch" "$delete_remote" "$stash_flag"
    elif [[ "$non_interactive" == "true" ]]; then
        wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
            "No worktree specified" \
            "In non-interactive mode, --worktree-name is required (or run from within a worktree)" \
            "Example: wt-delete --non-interactive --worktree-name my-feature"
    else
        wt_select_worktree_menu "$non_interactive" "$delete_branch" "$delete_remote" "$stash_flag"
    fi
}

main "$@"
