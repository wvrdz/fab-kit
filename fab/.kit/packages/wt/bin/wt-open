#!/usr/bin/env bash
#
# wt-open - Open a git worktree in an application
#
# Usage: wt-open [OPTIONS] [NAME|PATH]
#        wt-open help
#
# Opens a worktree in a detected application (editor, terminal, file manager).
# When called without arguments from a worktree, opens the current worktree.
# When called without arguments from the main repo, shows a selection menu.

set -euo pipefail

# ============================================================================
# Initialization
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wt-common.sh"

# ============================================================================
# Application Detection and Menu
# ============================================================================

# Global array to store available apps (name:open_cmd pairs)
declare -a WT_AVAILABLE_APPS=()

# Check if an application is available
wt_app_available() {
    local cli="${1:-}"
    local bundle_id="${2:-}"
    local desktop_file="${3:-}"
    local os
    os=$(wt_detect_os)

    # Check CLI command first
    if [[ -n "$cli" ]] && command -v "$cli" &>/dev/null; then
        return 0
    fi

    # OS-specific detection
    if [[ "$os" == "macos" && -n "$bundle_id" ]]; then
        if mdfind "kMDItemCFBundleIdentifier == '$bundle_id'" 2>/dev/null | grep -q .; then
            return 0
        fi
    elif [[ "$os" == "linux" && -n "$desktop_file" ]]; then
        if [[ -f "/usr/share/applications/$desktop_file" ]] || \
           [[ -f "$HOME/.local/share/applications/$desktop_file" ]]; then
            return 0
        fi
    fi

    return 1
}

# Build list of available applications
wt_build_available_apps() {
    local os
    os=$(wt_detect_os)
    WT_AVAILABLE_APPS=()

    # VSCode
    if wt_app_available "code" "com.microsoft.VSCode" "code.desktop"; then
        WT_AVAILABLE_APPS+=("VSCode:code")
    fi

    # Cursor
    if wt_app_available "cursor" "com.todesktop.230313mzl4w4u92" "cursor.desktop"; then
        WT_AVAILABLE_APPS+=("Cursor:cursor")
    fi

    # Ghostty
    if [[ "$os" == "macos" ]]; then
        if wt_app_available "ghostty" "com.mitchellh.ghostty" ""; then
            WT_AVAILABLE_APPS+=("Ghostty:ghostty_macos")
        fi
    else
        if wt_app_available "ghostty" "" "com.mitchellh.ghostty.desktop"; then
            WT_AVAILABLE_APPS+=("Ghostty:ghostty_linux")
        fi
    fi

    # macOS-only terminals
    if [[ "$os" == "macos" ]]; then
        if wt_app_available "" "com.googlecode.iterm2" ""; then
            WT_AVAILABLE_APPS+=("iTerm2:iterm")
        fi
        if wt_app_available "" "com.apple.Terminal" ""; then
            WT_AVAILABLE_APPS+=("Terminal.app:terminal_app")
        fi
    fi

    # Linux-only terminals
    if [[ "$os" == "linux" ]]; then
        if wt_app_available "gnome-terminal" "" "org.gnome.Terminal.desktop"; then
            WT_AVAILABLE_APPS+=("GNOME Terminal:gnome_terminal")
        fi
        if wt_app_available "konsole" "" "org.kde.konsole.desktop"; then
            WT_AVAILABLE_APPS+=("Konsole:konsole")
        fi
    fi

    # File managers
    if [[ "$os" == "macos" ]]; then
        WT_AVAILABLE_APPS+=("Finder:finder")
    else
        if wt_app_available "nautilus" "" "org.gnome.Nautilus.desktop"; then
            WT_AVAILABLE_APPS+=("Nautilus:nautilus")
        fi
        if wt_app_available "dolphin" "" "org.kde.dolphin.desktop"; then
            WT_AVAILABLE_APPS+=("Dolphin:dolphin")
        fi
    fi

    # Copy path option
    if [[ "$os" == "macos" ]] && command -v pbcopy &>/dev/null; then
        WT_AVAILABLE_APPS+=("Copy path:copy_macos")
    elif [[ "$os" == "linux" ]] && command -v xclip &>/dev/null; then
        WT_AVAILABLE_APPS+=("Copy path:copy_linux")
    fi

    # Byobu tab option (only within byobu session)
    if wt_is_byobu_session; then
        WT_AVAILABLE_APPS+=("Byobu tab:byobu_tab")
    fi

    # tmux window option (only within plain tmux session, not byobu)
    if wt_is_tmux_session; then
        WT_AVAILABLE_APPS+=("tmux window:tmux_window")
    fi
}

# Copy path to clipboard
wt_copy_to_clipboard() {
    local path="$1"
    local os
    os=$(wt_detect_os)

    if [[ "$os" == "macos" ]]; then
        echo -n "$path" | pbcopy
        echo "Path copied to clipboard"
    elif command -v xclip &>/dev/null; then
        echo -n "$path" | xclip -selection clipboard
        echo "Path copied to clipboard"
    else
        echo "Clipboard not available"
    fi
}

# Open worktree in specified application
wt_open_in_app() {
    local cmd="$1"
    local path="$2"

    case "$cmd" in
        code)
            code "$path"
            ;;
        cursor)
            cursor "$path"
            ;;
        ghostty_macos)
            open -a Ghostty "$path"
            ;;
        ghostty_linux)
            ghostty -e bash -c 'cd "$1" && exec "$SHELL"' _ "$path" &
            ;;
        iterm)
            open -a iTerm "$path"
            ;;
        terminal_app)
            open -a Terminal "$path"
            ;;
        gnome_terminal)
            gnome-terminal --working-directory="$path" &
            ;;
        konsole)
            konsole --workdir "$path" &
            ;;
        finder)
            open "$path"
            ;;
        nautilus)
            nautilus "$path" &
            ;;
        dolphin)
            dolphin "$path" &
            ;;
        copy_macos|copy_linux)
            wt_copy_to_clipboard "$path"
            ;;
        tmux_window)
            local tab_name="${WT_REPO_NAME}-${WT_NAME}"
            if ! command -v tmux &>/dev/null; then
                wt_error_with_code "$WT_EXIT_TMUX_WINDOW_ERROR" \
                    "Failed to open tmux window" \
                    "tmux is not available on this system" \
                    "Install tmux or choose a different option"
            fi
            if ! tmux new-window -n "$tab_name" -c "$path"; then
                wt_error_with_code "$WT_EXIT_TMUX_WINDOW_ERROR" \
                    "Failed to open tmux window" \
                    "tmux new-window failed" \
                    "Verify tmux session is active and retry"
            fi
            ;;
        byobu_tab)
            local tab_name="${WT_REPO_NAME}-${WT_NAME}"
            if ! command -v byobu &>/dev/null; then
                wt_error_with_code "$WT_EXIT_BYOBU_TAB_ERROR" \
                    "Failed to open byobu tab" \
                    "byobu is not available on this system" \
                    "Install byobu or choose a different option"
            fi
            # Clean up corrupted byobu cache
            local byobu_cache="${HOME}/.cache/byobu/.last.tmux"
            if [[ -d "$byobu_cache" ]]; then
                rm -rf "$byobu_cache" 2>/dev/null || true
            fi
            if ! byobu new-window -n "$tab_name" -c "$path"; then
                wt_error_with_code "$WT_EXIT_BYOBU_TAB_ERROR" \
                    "Failed to open byobu tab" \
                    "byobu new-window failed" \
                    "Verify byobu session is active and retry"
            fi
            ;;
        *)
            echo "Unknown application: $cmd" >&2
            return 1
            ;;
    esac
}

# Resolve an app name to a command key
# Matches against command keys directly, or display names (case-insensitive)
# Args: $1 = user-provided app name
# Returns: command key on stdout, exit 1 if not found
wt_resolve_app() {
    local input="$1"
    local input_lower
    input_lower=$(echo "$input" | tr '[:upper:]' '[:lower:]')

    wt_build_available_apps

    # First: exact match on command key
    for app in "${WT_AVAILABLE_APPS[@]}"; do
        local cmd="${app##*:}"
        if [[ "$cmd" == "$input" ]]; then
            echo "$cmd"
            return 0
        fi
    done

    # Second: case-insensitive match on display name
    for app in "${WT_AVAILABLE_APPS[@]}"; do
        local name="${app%%:*}"
        local cmd="${app##*:}"
        local name_lower
        name_lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')
        if [[ "$name_lower" == "$input_lower" ]]; then
            echo "$cmd"
            return 0
        fi
    done

    return 1
}

# Detect best default app based on context
wt_detect_default_app() {
    local suggested_cmd=""

    # Check for VS Code terminal
    if [[ "${TERM_PROGRAM:-}" == "vscode" ]]; then
        suggested_cmd="code"
    # Check for Cursor terminal
    elif [[ "${TERM_PROGRAM:-}" == "cursor" ]]; then
        suggested_cmd="cursor"
    # Check for byobu session
    elif wt_is_byobu_session; then
        suggested_cmd="byobu_tab"
    # Check for tmux session
    elif wt_is_tmux_session; then
        suggested_cmd="tmux_window"
    # Check last-used app from cache
    elif [[ -f ~/.cache/wt/last-app ]]; then
        suggested_cmd=$(cat ~/.cache/wt/last-app 2>/dev/null || echo "")
    fi

    # Find the index of suggested app in available apps
    if [[ -n "$suggested_cmd" ]]; then
        local idx=1
        for app in "${WT_AVAILABLE_APPS[@]}"; do
            local cmd="${app##*:}"
            if [[ "$cmd" == "$suggested_cmd" ]]; then
                echo "$idx"
                return 0
            fi
            ((idx++))
        done
    fi

    # Default to first app if no match
    echo "1"
}

# Save last-used app to cache
wt_save_last_app() {
    local cmd="$1"
    mkdir -p ~/.cache/wt
    echo "$cmd" > ~/.cache/wt/last-app
}

# Interactive menu using shared wt_show_menu
wt_handle_menu() {
    local wt_path="$1"

    wt_build_available_apps

    if [[ ${#WT_AVAILABLE_APPS[@]} -eq 0 ]]; then
        echo "No supported applications detected."
        return 0
    fi

    # Detect default app
    local default_idx
    default_idx=$(wt_detect_default_app)

    # Extract app names for the menu
    local app_names=()
    for app in "${WT_AVAILABLE_APPS[@]}"; do
        app_names+=("${app%%:*}")
    done

    wt_show_menu "Open in:" "$default_idx" "${app_names[@]}"

    if [[ "$WT_MENU_CHOICE" == "0" ]]; then
        return 0
    fi

    local selected="${WT_AVAILABLE_APPS[$((WT_MENU_CHOICE - 1))]}"
    local open_cmd="${selected##*:}"

    # Save last-used app
    wt_save_last_app "$open_cmd"

    wt_open_in_app "$open_cmd" "$wt_path"
}

# ============================================================================
# Worktree Selection
# ============================================================================

# Show worktree selection menu, then open the chosen one
wt_select_and_open() {
    wt_get_repo_context

    local worktrees=()
    local names=()
    local default_idx=1

    # Find most recently modified worktree
    local newest_path=""
    local newest_time=0

    while IFS=$'\t' read -r path branch; do
        if [[ "$path" != "$WT_REPO_ROOT" ]]; then
            local name
            name=$(basename "$path")
            worktrees+=("$path")
            names+=("$name ($branch)")

            # Track most recent
            if [[ -d "$path" ]]; then
                local mtime
                mtime=$(stat -c %Y "$path" 2>/dev/null || stat -f %m "$path" 2>/dev/null || echo 0)
                if ((mtime > newest_time)); then
                    newest_time=$mtime
                    newest_path="$path"
                fi
            fi
        fi
    done < <(wt_list_worktrees)

    if [[ ${#worktrees[@]} -eq 0 ]]; then
        echo "No worktrees found."
        exit "$WT_EXIT_SUCCESS"
    fi

    # Find index of newest worktree
    if [[ -n "$newest_path" ]]; then
        for i in "${!worktrees[@]}"; do
            if [[ "${worktrees[$i]}" == "$newest_path" ]]; then
                default_idx=$((i + 1))
                break
            fi
        done
    fi

    wt_show_menu "Select worktree to open:" "$default_idx" "${names[@]}"

    if [[ "$WT_MENU_CHOICE" == "0" ]]; then
        echo "Cancelled."
        exit "$WT_EXIT_SUCCESS"
    fi

    local selected_path="${worktrees[$((WT_MENU_CHOICE - 1))]}"
    WT_NAME=$(basename "$selected_path")
    wt_handle_menu "$selected_path"
}

# ============================================================================
# Help
# ============================================================================

wt_show_help() {
    cat <<EOF
Usage: wt-open [OPTIONS] [NAME|PATH]

Opens a git worktree in a detected application (editor, terminal, file manager).

Arguments:
  NAME    Worktree name to open (optional)
  PATH    Direct path to open (optional)
          If omitted from within a worktree, opens current worktree
          If omitted from main repo, shows selection menu

Options:
  --app <name>    Open in specified app, skipping the menu
                  Accepts command keys: code, cursor, ghostty, tmux_window, byobu_tab
                  Or display names: VSCode, Cursor, Ghostty, etc.
  help            Show this help message

Examples:
  wt-open                       # Open current worktree (or select from list)
  wt-open swift-fox             # Open worktree named 'swift-fox'
  wt-open --app code swift-fox  # Open in VSCode without menu
  wt-open --app tmux_window     # Open current worktree in new tmux window
EOF
}

# ============================================================================
# Main Entry Point
# ============================================================================

main() {
    local target=""
    local app_flag=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            help|--help|-h)
                wt_show_help
                exit "$WT_EXIT_SUCCESS"
                ;;
            --app)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing app name" \
                        "--app requires an argument" \
                        "Example: wt-open --app code"
                fi
                app_flag="$2"
                shift 2
                ;;
            -*)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unknown option: $1" \
                    "This option is not recognized" \
                    "Run 'wt-open help' for usage information"
                ;;
            *)
                if [[ -z "$target" ]]; then
                    target="$1"
                else
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Too many arguments" \
                        "Only one target can be specified" \
                        "Run 'wt-open help' for usage information"
                fi
                shift
                ;;
        esac
    done

    wt_validate_git_repo
    wt_get_repo_context

    local wt_path=""

    if [[ -n "$target" ]]; then
        if [[ -d "$target" ]]; then
            # Direct path
            wt_path="$target"
            WT_NAME=$(basename "$wt_path")
        else
            # Try as worktree name
            wt_path=$(wt_get_worktree_path_by_name "$target") || {
                wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
                    "Worktree '$target' not found" \
                    "No worktree with that name and not an existing directory" \
                    "Use 'wt-list' to see available worktrees"
            }
            WT_NAME="$target"
        fi
    elif wt_is_worktree; then
        # In a worktree - open it
        wt_path=$(git rev-parse --show-toplevel 2>/dev/null)
        WT_NAME=$(basename "$wt_path")
    else
        if [[ -n "$app_flag" ]]; then
            wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                "No worktree specified" \
                "--app requires a worktree name or path, or run from within a worktree" \
                "Example: wt-open --app code my-worktree"
        fi
        # In main repo - show selection
        wt_select_and_open
        return
    fi

    # Open with specified app or show menu
    if [[ -n "$app_flag" ]]; then
        local resolved_cmd
        resolved_cmd=$(wt_resolve_app "$app_flag") || {
            wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
                "Unknown app: $app_flag" \
                "App '$app_flag' is not available on this system" \
                "Available apps can be seen with: wt-open (then check the menu)"
        }
        wt_open_in_app "$resolved_cmd" "$wt_path"
    else
        wt_handle_menu "$wt_path"
    fi
}

main "$@"
