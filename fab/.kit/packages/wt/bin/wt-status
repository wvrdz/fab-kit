#!/usr/bin/env bash
#
# wt-status - Show fab pipeline status for worktrees
#
# Usage: wt-status [OPTIONS] [<name>]
#        wt-status help

set -euo pipefail

# ============================================================================
# Initialization
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wt-common.sh"

# ============================================================================
# Fab Status Resolution (Atomic Unit)
# ============================================================================

# Get fab pipeline status for a single worktree path.
# Args: $1 = worktree path
# Sets: WT_FAB_CHANGE, WT_FAB_STAGE, WT_FAB_STATE
wt_get_fab_status() {
    local wt_path="$1"

    WT_FAB_CHANGE=""
    WT_FAB_STAGE=""
    WT_FAB_STATE=""

    # Check if fab/ directory exists in this worktree
    if [[ ! -d "$wt_path/fab" ]]; then
        WT_FAB_CHANGE="(no fab)"
        return 0
    fi

    # Check if fab/current exists and is non-empty
    local current_file="$wt_path/fab/current"
    if [[ ! -f "$current_file" ]] || [[ ! -s "$current_file" ]]; then
        WT_FAB_CHANGE="(no change)"
        return 0
    fi

    # Read folder name from line 2 of fab/current
    local folder_name
    folder_name=$(sed -n '2p' "$current_file" 2>/dev/null | tr -d '[:space:]')
    if [[ -z "$folder_name" ]]; then
        WT_FAB_CHANGE="(no change)"
        return 0
    fi

    # Check if the change directory and .status.yaml exist
    local status_file="$wt_path/fab/changes/$folder_name/.status.yaml"
    if [[ ! -f "$status_file" ]]; then
        WT_FAB_CHANGE="(stale)"
        return 0
    fi

    WT_FAB_CHANGE="$folder_name"

    # Locate statusman.sh relative to the worktree's kit
    local statusman="$wt_path/fab/.kit/scripts/lib/statusman.sh"
    if [[ ! -f "$statusman" ]]; then
        # Fallback: try to find it via our own kit location
        statusman="$SCRIPT_DIR/../../../scripts/lib/statusman.sh"
    fi

    if [[ -f "$statusman" ]]; then
        local display_output
        display_output=$("$statusman" display-stage "$status_file" 2>/dev/null) || display_output="unknown:unknown"
        WT_FAB_STAGE="${display_output%%:*}"
        WT_FAB_STATE="${display_output#*:}"
    else
        WT_FAB_STAGE="unknown"
        WT_FAB_STATE="unknown"
    fi
}

# ============================================================================
# Single Worktree Display
# ============================================================================

# Show fab status for a single worktree.
# Args: $1 = worktree path, $2 = display name
wt_show_single_status() {
    local wt_path="$1"
    local name="$2"

    wt_get_fab_status "$wt_path"

    if [[ -n "$WT_FAB_STAGE" ]]; then
        printf "%s  %s  %s  %s\n" "$name" "$WT_FAB_CHANGE" "$WT_FAB_STAGE" "$WT_FAB_STATE"
    else
        printf "%s  %s\n" "$name" "$WT_FAB_CHANGE"
    fi
}

# ============================================================================
# All Worktrees Display
# ============================================================================

wt_show_all_status() {
    wt_get_repo_context
    local current_path
    current_path=$(pwd -P)

    echo "Worktrees for: ${WT_BOLD}$WT_REPO_NAME${WT_RESET}"
    echo "Location: $WT_WORKTREES_DIR"
    echo ""

    local count=0
    while IFS=$'\t' read -r path branch; do
        local name marker=""

        if [[ "$path" == "$current_path" ]]; then
            marker="${WT_GREEN}*${WT_RESET} "
        else
            marker="  "
        fi

        if [[ "$path" == "$WT_REPO_ROOT" ]]; then
            name="(main)"
        else
            name=$(basename "$path")
        fi

        wt_get_fab_status "$path"

        if [[ -n "$WT_FAB_STAGE" ]]; then
            printf "%s%-14s %-42s %-10s %s\n" "$marker" "$name" "$WT_FAB_CHANGE" "$WT_FAB_STAGE" "$WT_FAB_STATE"
        else
            printf "%s%-14s %s\n" "$marker" "$name" "$WT_FAB_CHANGE"
        fi

        count=$((count + 1))
    done < <(wt_list_worktrees)

    echo ""
    echo "Total: $count worktree(s)"
}

# ============================================================================
# Help
# ============================================================================

wt_show_help() {
    cat <<EOF
Usage: wt-status [OPTIONS] [<name>]

Shows the fab pipeline status (stage + state) for worktrees.

By default, shows the status of the current worktree.

Options:
  --all         Show status for all worktrees
  help          Show this help message

Arguments:
  <name>        Show status for a specific worktree by name

Examples:
  wt-status                   # Current worktree's fab status
  wt-status swift-fox         # Specific worktree's fab status
  wt-status --all             # All worktrees' fab status
EOF
}

# ============================================================================
# Main Entry Point
# ============================================================================

main() {
    local mode="current"
    local target_name=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            help|--help|-h)
                wt_show_help
                exit "$WT_EXIT_SUCCESS"
                ;;
            --all)
                mode="all"
                shift
                ;;
            -*)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unknown option: $1" \
                    "This option is not recognized" \
                    "Run 'wt-status help' for usage information"
                ;;
            *)
                if [[ -n "$target_name" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Unexpected argument: $1" \
                        "Only one worktree name can be specified" \
                        "Run 'wt-status help' for usage information"
                fi
                target_name="$1"
                mode="named"
                shift
                ;;
        esac
    done

    wt_validate_git_repo

    case "$mode" in
        current)
            wt_get_repo_context
            local current_path name
            current_path=$(pwd -P)
            if [[ "$current_path" == "$WT_REPO_ROOT" ]]; then
                name="(main)"
            else
                name=$(basename "$current_path")
            fi
            wt_show_single_status "$current_path" "$name"
            ;;
        named)
            wt_get_repo_context
            local found_path
            found_path=$(wt_get_worktree_path_by_name "$target_name") || {
                wt_error_with_code "$WT_EXIT_GENERAL_ERROR" \
                    "Worktree '$target_name' not found" \
                    "No worktree with that name exists" \
                    "Use 'wt-status --all' to see available worktrees"
            }
            wt_show_single_status "$found_path" "$target_name"
            ;;
        all)
            wt_show_all_status
            ;;
    esac
}

main "$@"
