#!/usr/bin/env bash
#
# wt-list - List all git worktrees
#
# Usage: wt-list [OPTIONS]
#        wt-list help

set -euo pipefail

# ============================================================================
# Initialization
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wt-common.sh"

# ============================================================================
# Status Helpers
# ============================================================================

# Get dirty/unpushed status for a worktree path
# Args: $1 = worktree path, $2 = branch name
# Sets: WT_STATUS_DIRTY (bool string), WT_STATUS_UNPUSHED (int)
wt_get_worktree_status() {
    local wt_path="$1"
    local branch="$2"

    WT_STATUS_DIRTY="false"
    WT_STATUS_UNPUSHED=0

    if [[ ! -d "$wt_path" ]]; then
        return
    fi

    # Check dirty state (uncommitted changes or untracked files)
    if (cd "$wt_path" && (wt_has_uncommitted_changes || wt_has_untracked_files)) 2>/dev/null; then
        WT_STATUS_DIRTY="true"
    fi

    # Check unpushed commits
    if [[ "$branch" != "(detached)" ]]; then
        local count
        count=$(cd "$wt_path" && wt_get_unpushed_count "$branch" 2>/dev/null) || count="0"
        WT_STATUS_UNPUSHED="${count:-0}"
    fi
}

# ============================================================================
# Path Lookup
# ============================================================================

wt_path_lookup() {
    local name="$1"

    wt_get_repo_context

    local found_path
    found_path=$(wt_get_worktree_path_by_name "$name") || {
        echo "Worktree '$name' not found. Use 'wt-list' to see available worktrees." >&2
        exit "$WT_EXIT_GENERAL_ERROR"
    }

    echo "$found_path"
}

# ============================================================================
# JSON Output
# ============================================================================

wt_list_json() {
    wt_get_repo_context
    local current_path
    current_path=$(pwd)

    local json_entries=()

    while IFS=$'\t' read -r path branch; do
        local name is_main is_current

        if [[ "$path" == "$WT_REPO_ROOT" ]]; then
            name="main"
            is_main="true"
        else
            name=$(basename "$path")
            is_main="false"
        fi

        if [[ "$path" == "$current_path" ]]; then
            is_current="true"
        else
            is_current="false"
        fi

        wt_get_worktree_status "$path" "$branch"

        json_entries+=("$(jq -n \
            --arg name "$name" \
            --arg branch "$branch" \
            --arg path "$path" \
            --argjson is_main "$is_main" \
            --argjson is_current "$is_current" \
            --argjson dirty "$WT_STATUS_DIRTY" \
            --argjson unpushed "$WT_STATUS_UNPUSHED" \
            '{name:$name, branch:$branch, path:$path, is_main:$is_main, is_current:$is_current, dirty:$dirty, unpushed:$unpushed}')")
    done < <(wt_list_worktrees)

    # Join entries and format with jq
    local joined
    joined=$(printf '%s\n' "${json_entries[@]}" | jq -s '.')
    echo "$joined"
}

# ============================================================================
# Formatted List (default)
# ============================================================================

wt_list_worktrees_formatted() {
    wt_get_repo_context
    local current_path
    current_path=$(pwd)

    echo "Worktrees for: ${WT_BOLD}$WT_REPO_NAME${WT_RESET}"
    echo "Location: $WT_WORKTREES_DIR"
    echo ""

    local count=0
    while IFS=$'\t' read -r path branch; do
        local name marker="" status=""

        if [[ "$path" == "$current_path" ]]; then
            marker="${WT_GREEN}*${WT_RESET} "
        else
            marker="  "
        fi

        if [[ "$path" == "$WT_REPO_ROOT" ]]; then
            name="${WT_BOLD}(main)${WT_RESET}"
        else
            name=$(basename "$path")
        fi

        # Build status indicators
        wt_get_worktree_status "$path" "$branch"
        local dirty_marker="" unpushed_marker=""
        if [[ "$WT_STATUS_DIRTY" == "true" ]]; then
            dirty_marker="${WT_YELLOW}*${WT_RESET}"
        fi
        if [[ "$WT_STATUS_UNPUSHED" -gt 0 ]]; then
            unpushed_marker="${WT_YELLOW}↑${WT_STATUS_UNPUSHED}${WT_RESET}"
        fi

        if [[ -n "$dirty_marker" && -n "$unpushed_marker" ]]; then
            status="$dirty_marker $unpushed_marker"
        elif [[ -n "$dirty_marker" ]]; then
            status="$dirty_marker"
        elif [[ -n "$unpushed_marker" ]]; then
            status="$unpushed_marker"
        fi

        printf "%s%-14s %-22s %-6s %s\n" "$marker" "$name" "$branch" "$status" "$path"
        count=$((count + 1))
    done < <(wt_list_worktrees)

    echo ""
    echo "Total: $count worktree(s)"
}

# ============================================================================
# Help
# ============================================================================

wt_show_help() {
    cat <<EOF
Usage: wt-list [OPTIONS]

Lists all git worktrees for the current repository.

The current worktree is marked with a green asterisk (*).
Dirty worktrees show * and unpushed commits show ↑N in the status column.

Options:
  --path <name>   Output just the absolute path for a named worktree
  --json          Output worktree data as a JSON array
  help            Show this help message

Examples:
  wt-list                   # List all worktrees with status
  wt-list --path swift-fox  # Get path for a specific worktree
  wt-list --json            # Machine-readable JSON output
EOF
}

# ============================================================================
# Main Entry Point
# ============================================================================

main() {
    local mode="formatted"
    local path_name=""
    local has_path="" has_json=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            help|--help|-h)
                wt_show_help
                exit "$WT_EXIT_SUCCESS"
                ;;
            --path)
                if [[ -z "${2:-}" ]]; then
                    wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                        "Missing worktree name" \
                        "--path requires a worktree name" \
                        "Example: wt-list --path swift-fox"
                fi
                has_path="true"
                mode="path"
                path_name="$2"
                shift 2
                ;;
            --json)
                has_json="true"
                mode="json"
                shift
                ;;
            -*)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unknown option: $1" \
                    "This option is not recognized" \
                    "Run 'wt-list help' for usage information"
                ;;
            *)
                wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
                    "Unexpected argument: $1" \
                    "wt-list does not accept positional arguments" \
                    "Run 'wt-list help' for usage information"
                ;;
        esac
    done

    # Check mutual exclusivity
    if [[ "$has_path" == "true" && "$has_json" == "true" ]]; then
        wt_error_with_code "$WT_EXIT_INVALID_ARGS" \
            "--path and --json are mutually exclusive" \
            "Use one output mode at a time" \
            "Run 'wt-list help' for usage information"
    fi

    wt_validate_git_repo

    case "$mode" in
        path)
            wt_path_lookup "$path_name"
            ;;
        json)
            wt_list_json
            ;;
        formatted)
            wt_list_worktrees_formatted
            ;;
    esac
}

main "$@"
